<?xml version="1.0"?>
<robot name="myAGV">

  <!-- ========================================================= -->
  <!-- mesh 파일을 전혀 쓰지 않는 순수 geometry(box/cylinder) URDF -->
  <!-- dae에서 측정한 실제 치수를 그대로 반영함                    -->
  <!-- 본체: 0.31 x 0.23 x 0.11 m  (myagv_base.dae 측정값)         -->
  <!-- ========================================================= -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0.0 0.0 0.06" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- ===== base_link: 본체 하단 (노란색 박스) ===== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.31 0.23 0.11"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <material name="yellow">
        <color rgba="0.95 0.75 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.31 0.23 0.11"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.0408" ixy="0.0" ixz="0.0"
               iyy="0.0642" iyz="0.0"
               izz="0.0897"/>
    </inertial>
  </link>

  <!-- ===== upper_link: 상판 (검은색 박스, base보다 살짝 작게) ===== -->
  <joint name="upper_joint" type="fixed">
    <origin xyz="0.0 0.0 0.075" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="upper_link"/>
  </joint>

  <link name="upper_link">
    <visual>
      <geometry>
        <box size="0.28 0.20 0.04"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <material name="dark_grey">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.28 0.20 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===== 바퀴 4개 ===== -->
  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.10 0.14 -0.045" rpy="-1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="front_left_wheel">
    <visual>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
      <material name="wheel_grey"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.10 -0.14 -0.045" rpy="-1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="front_right_wheel">
    <visual>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
      <material name="wheel_grey"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <origin xyz="-0.10 0.14 -0.045" rpy="-1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="rear_left_wheel">
    <visual>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
      <material name="wheel_grey"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <origin xyz="-0.10 -0.14 -0.045" rpy="-1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="rear_right_wheel">
    <visual>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
      <material name="wheel_grey"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.055" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <!-- ===== LiDAR ===== -->
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.0 0.0 0.13" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="laser_frame"/>
  </joint>
  <link name="laser_frame">
    <visual>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===== Front Camera (ArUco 인식용) ===== -->
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.16 0.0 0.04" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>
  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.05 0.02"/></geometry>
      <material name="cam_black"><color rgba="0.05 0.05 0.05 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.05 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- ROS 카메라 표준 광학 좌표축 (z앞, x우, y아래) -->
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="camera_link"/>
    <child link="camera_link_optical"/>
  </joint>
  <link name="camera_link_optical"/>

  <!-- ===== Gazebo: diff_drive plugin ===== -->
  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <wheel_separation>0.28</wheel_separation>
      <wheel_diameter>0.11</wheel_diameter>
      <max_wheel_torque>50</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <!-- 앞바퀴: 일반 마찰 -->
  <gazebo reference="front_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1><mu2>1.5</mu2>
    <kp>100000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth><maxVel>100</maxVel>
  </gazebo>
  <gazebo reference="front_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1><mu2>1.5</mu2>
    <kp>100000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth><maxVel>100</maxVel>
  </gazebo>

  <!-- 뒷바퀴: 낮은 마찰 (회전 시 끌림 방지) -->
  <gazebo reference="rear_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.05</mu1><mu2>0.05</mu2>
    <kp>100000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth><maxVel>100</maxVel>
  </gazebo>
  <gazebo reference="rear_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.05</mu1><mu2>0.05</mu2>
    <kp>100000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth><maxVel>100</maxVel>
  </gazebo>

  <!-- ===== Gazebo: LiDAR 센서 ===== -->
  <gazebo reference="laser_frame">
    <material>Gazebo/Black</material>
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== Gazebo: Front Camera (ArUco 인식용) ===== -->
  <gazebo reference="camera_link">
    <material>Gazebo/FlatBlack</material>
    <sensor type="camera" name="front_camera">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>15</update_rate>
      <camera name="front_camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>15.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
        </ros>
        <camera_name>front_camera</camera_name>
        <frame_name>camera_link_optical</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
